{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "gotglyphed2",
  "post": {
    "dir": "webroot",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "New Glyphed Puzzle Post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/create-post"
      }
    ]
  },
  "permissions": {
    "redis": true,
    "reddit": true
  },
  "dev": {
    "subreddit": "gotglyphed_dev"
  }
}